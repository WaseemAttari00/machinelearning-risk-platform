# Copy this file to .env and fill in values for your environment.
# .env is gitignored — never commit secrets or local paths.

# API
API_HOST=0.0.0.0
API_PORT=8000

# Frontend (use http://api:8000 when running inside Docker Compose)
STREAMLIT_PORT=8501
API_URL=http://localhost:8000

# MLflow
MLFLOW_TRACKING_URI=mlruns
MLFLOW_PORT=5000

# Training
RANDOM_STATE=42
